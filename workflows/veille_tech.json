        "script_code": "def run(github_data):\n    items = github_data.get('items', [])\n    lines = ['=== Top 5 GitHub Python Repos ===']\n    for i, repo in enumerate(items[:5], 1):\n        name = repo.get('full_name', 'unknown')\n        stars = repo.get('stargazers_count', 0)\n        desc = (repo.get('description') or '')[:80]\n        lines.append(f'{i}. {name} — {stars:,} stars')\n        if desc:\n            lines.append(f'   {desc}')\n    return '\\n'.join(lines)",
