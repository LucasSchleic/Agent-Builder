        "script_code": "def run():\n    import os\n    from datetime import datetime\n    OUTPUT_DIR = 'rapports'\n    TITRE = 'Rapport quotidien'\n    NB_LIGNES = 5\n    os.makedirs(OUTPUT_DIR, exist_ok=True)\n    now = datetime.now().strftime('%Y%m%d_%H%M%S')\n    lines = [TITRE, '=' * len(TITRE), '']\n    for i in range(1, NB_LIGNES + 1):\n        lines.append(f'  Ligne {i} : donnee generee automatiquement')\n    lines += ['', f'Genere le {datetime.now().strftime(\"%d/%m/%Y %H:%M\")}']\n    content = '\\n'.join(lines)\n    path = os.path.join(OUTPUT_DIR, f'rapport_{now}.txt')\n    with open(path, 'w', encoding='utf-8') as f:\n        f.write(content)\n    return f'{NB_LIGNES} lignes ecrites dans {path}'",
