    {
      "id": "87a33940-d862-4a98-894c-1cc9c78052f0",
      "type": "PythonScriptBlock",
      "name": "Compiler Donnees",
      "config": {
        "function_name": "compiler_donnees",
        "script_code": "def compiler_donnees(post_data, user_data):\n    titre = post_data.get('title', 'N/A') if isinstance(post_data, dict) else str(post_data)\n    corps = post_data.get('body', 'N/A') if isinstance(post_data, dict) else ''\n    nom = user_data.get('name', 'N/A') if isinstance(user_data, dict) else str(user_data)\n    email = user_data.get('email', 'N/A') if isinstance(user_data, dict) else ''\n    ville = user_data.get('address', {}).get('city', 'N/A') if isinstance(user_data, dict) else ''\n    entreprise = user_data.get('company', {}).get('name', 'N/A') if isinstance(user_data, dict) else ''\n    return f\"Auteur: {nom} | {email} | {ville} | {entreprise}\\nTitre du post: {titre}\\nContenu: {corps}\"\n",
        "detected_inputs": ["post_data", "user_data"],
        "detected_outputs": ["output"]
      },
      "input_ports": [
        { "id": "4e1016ab-5e8e-47f5-afce-50f6e201d126", "name": "post_data", "direction": "input", "data_type": "any", "required": true },
        { "id": "b371b79d-4daa-412c-b883-df785bf75988", "name": "user_data", "direction": "input", "data_type": "any", "required": true }
      ],
      "output_ports": [
        { "id": "a340149d-52c1-426b-a09e-d126a24e0aa8", "name": "output", "direction": "output", "data_type": "any", "required": false }
      ]
    },
    {
      "id": "ea2f4532-4662-4697-9d9d-4af4c0c24a8d",
      "type": "PythonScriptBlock",
      "name": "Stats Texte",
      "config": {
        "function_name": "stats_texte",
        "script_code": "def stats_texte(texte_compile):\n    if not isinstance(texte_compile, str):\n        texte_compile = str(texte_compile)\n    mots = len(texte_compile.split())\n    lignes = len(texte_compile.splitlines())\n    caracteres = len(texte_compile)\n    print(f'[Stats] {mots} mots, {lignes} lignes, {caracteres} caracteres')\n    return f\"=== Rapport de donnees ===\\n{texte_compile}\\n\\n--- Statistiques ---\\nMots: {mots} | Lignes: {lignes} | Caracteres: {caracteres}\"\n",
        "detected_inputs": ["texte_compile"],
        "detected_outputs": ["output"]
      },
      "input_ports": [
        { "id": "b60e1b6e-1d88-4224-a5f9-217ed30d9be0", "name": "texte_compile", "direction": "input", "data_type": "any", "required": true }
      ],
      "output_ports": [
        { "id": "f9f44f92-b812-4e2e-bab7-1b850061f45e", "name": "output", "direction": "output", "data_type": "any", "required": false }
      ]
    },
