    {
      "id": "ed-scr-0007-0000-0000-0000-000000000001",
      "type": "PythonScriptBlock",
      "name": "Rapport Editorial",
      "config": {
        "function_name": "run",
        "script_code": "def run(bilan, recommandations):\n    from datetime import datetime\n    import os\n    now = datetime.now().strftime('%d/%m/%Y %H:%M')\n    sep = '=' * 60\n    thin = '-' * 60\n    content = sep + '\\n  RAPPORT EDITORIAL\\n  Genere le ' + now + '\\n' + sep + '\\n\\n' + bilan + '\\n\\n' + thin + '\\n  RECOMMANDATIONS (AGENT)\\n' + thin + '\\n\\n' + recommandations + '\\n\\n' + sep\n    filename = 'workflows/rapport_' + datetime.now().strftime('%Y%m%d_%H%M%S') + '.txt'\n    os.makedirs('workflows', exist_ok=True)\n    with open(filename, 'w', encoding='utf-8') as f:\n        f.write(content)\n    return 'Rapport ecrit dans ' + filename + '\\n\\n' + content",
        "detected_inputs": ["bilan", "recommandations"],
        "detected_outputs": ["output"]
      },
