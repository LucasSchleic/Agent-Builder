      "id": "ed-scr-0005-0000-0000-0000-000000000001",
      "type": "PythonScriptBlock",
      "name": "Bilan Operations",
      "config": {
        "function_name": "run",
        "script_code": "def run(articles, publication, archivage):\n    nb = len(articles) if isinstance(articles, list) else 1\n    pub_id    = publication.get('id', '?') if isinstance(publication, dict) else '?'\n    pub_title = publication.get('title', '?')[:55] if isinstance(publication, dict) else str(publication)[:55]\n    pub_code  = str(publication.get('_status', 201)) if isinstance(publication, dict) else '?'\n    arch_ok   = archivage == {} or archivage == '{}'\n    arch_msg  = 'OK (200)' if arch_ok else str(archivage)[:50]\n    lines = [\n        '=== BILAN OPERATIONS API ===',\n        '',\n        '  GET    /posts?userId=1  : ' + str(nb) + ' articles recuperes',\n        '  POST   /posts          : ID=' + str(pub_id) + ' — ' + pub_title,\n        '  DELETE /posts/2        : ' + arch_msg,\n        '',\n        'API cible : jsonplaceholder.typicode.com',\n    ]\n    return '\\n'.join(lines)",
        "detected_inputs": ["articles", "publication", "archivage"],
        "detected_outputs": ["output"]
      },
