        "script_code": "def run(analyse):\n    import requests\n    payload = {\n        'title': 'Rapport Incidents Automatique',\n        'body': analyse,\n        'userId': 1\n    }\n    r = requests.post('https://jsonplaceholder.typicode.com/posts', json=payload)\n    data = r.json()\n    return f'POST /posts → status {r.status_code} — ID attribué : {data.get(\"id\")}'",
        "detected_inputs": ["analyse"],
        "detected_outputs": ["output"]
