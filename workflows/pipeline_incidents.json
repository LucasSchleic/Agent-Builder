      "id": "pi-script-0007-0000-0000-0000-000000000001",
      "type": "PythonScriptBlock",
      "name": "Rapport Final",
      "config": {
        "function_name": "run",
        "script_code": "def run(analyse, recommandations, rapport_api):\n    from datetime import datetime\n    import os\n    now = datetime.now().strftime('%d/%m/%Y %H:%M')\n    sep = '=' * 60\n    thin = '-' * 60\n    report = '\\n'.join([\n        sep,\n        '  RAPPORT PIPELINE INCIDENTS',\n        f'  Généré le {now}',\n        sep,\n        '',\n        analyse,\n        '',\n        thin,\n        '  RECOMMANDATIONS DE L\\'AGENT',\n        thin,\n        '',\n        recommandations,\n        '',\n        thin,\n        '  STATUT PUBLICATION API',\n        thin,\n        '',\n        rapport_api,\n        '',\n        sep,\n    ])\n    filename = f'workflows/rapport_{datetime.now().strftime(\"%Y%m%d_%H%M%S\")}.txt'\n    os.makedirs('workflows', exist_ok=True)\n    with open(filename, 'w', encoding='utf-8') as f:\n        f.write(report)\n    return f'Rapport écrit dans {filename}\\n\\n' + report",
        "detected_inputs": ["analyse", "recommandations", "rapport_api"],
        "detected_outputs": ["output"]
