    {
      "id": "pi-script-0004-0000-0000-0000-000000000001",
      "type": "PythonScriptBlock",
      "name": "Analyseur Incidents",
      "config": {
        "function_name": "run",
        "script_code": "def run(incidents, equipe):\n    user_map = {u['id']: u['name'] for u in equipe}\n    by_user = {}\n    for t in incidents:\n        uid = t['userId']\n        by_user.setdefault(uid, []).append(t['title'])\n    lines = ['=== ANALYSE INCIDENTS OUVERTS ===']\n    lines.append(f'Total incidents non résolus : {len(incidents)}')\n    lines.append('')\n    for uid, tasks in sorted(by_user.items(), key=lambda x: -len(x[1])):\n        name = user_map.get(uid, f'Utilisateur {uid}')\n        lines.append(f'  {name} — {len(tasks)} incident(s)')\n        for t in tasks[:3]:\n            lines.append(f'    · {t[:70]}')\n        if len(tasks) > 3:\n            lines.append(f'    ... et {len(tasks) - 3} autres')\n    return '\\n'.join(lines)",
        "detected_inputs": ["incidents", "equipe"],
        "detected_outputs": ["output"]
      },
      "input_ports": [
        {"id": "pi-script-0004-0000-0000-0000-000000000002", "name": "incidents", "direction": "input", "data_type": "any", "required": true},
