    {
      "id": "tdb-scr-006",
      "type": "PythonScriptBlock",
      "name": "Analyser Taches",
      "config": {
        "function_name": "run",
        "script_code": "def run(taches):\n    if not isinstance(taches, list):\n        return {'total': 0, 'faites': 0, 'a_faire': 0, 'titres_en_attente': []}\n    faites = [t for t in taches if t.get('completed')]\n    a_faire = [t for t in taches if not t.get('completed')]\n    return {\n        'total': len(taches),\n        'faites': len(faites),\n        'a_faire': len(a_faire),\n        'titres_en_attente': [t.get('title', '?') for t in a_faire[:3]]\n    }",
        "detected_inputs": ["taches"],
        "detected_outputs": ["output"]
      },
      "input_ports": [
        {"id": "tdb-scr-006-in", "name": "taches", "direction": "input", "data_type": "any", "required": true}
      ],
      "output_ports": [
        {"id": "tdb-scr-006-out", "name": "output", "direction": "output", "data_type": "any", "required": false}
      ]
    },
    {
      "id": "tdb-agt-007",
      "type": "AgentBlock",
      "name": "Chef de Projet",
      "config": {
        "system_prompt": "Tu es un chef de projet experimente. Tu as acces aux taches via ton outil. Sois concis et oriente action. Reponds en francais.",
        "user_prompt": "Consulte les taches disponibles via ton outil. Identifie les 2 priorites les plus urgentes et propose un plan d'action concret en 3 etapes.",
        "memory_enabled": false,
        "llm_block_id": "tdb-llm-001",
        "tool_block_ids": ["tdb-http-002"]
      },
      "input_ports": [
        {"id": "tdb-agt-007-llm", "name": "llm_input",  "direction": "input", "data_type": "llm",  "required": true},
        {"id": "tdb-agt-007-tool", "name": "tool_input", "direction": "input", "data_type": "tool", "required": false}
      ],
      "output_ports": [
        {"id": "tdb-agt-007-out", "name": "agent_output", "direction": "output", "data_type": "str", "required": false}
      ]
    },
    {
      "id": "tdb-scr-008",
      "type": "PythonScriptBlock",
      "name": "Rapport Final",
      "config": {
        "function_name": "run",
        "script_code": "def run(analyse, creation, validation, suppression, recommandations):\n    from datetime import datetime\n    import os\n    now = datetime.now().strftime('%d/%m/%Y %H:%M')\n    sep = '=' * 60\n    thin = '-' * 60\n    total = analyse.get('total', 0) if isinstance(analyse, dict) else 0\n    faites = analyse.get('faites', 0) if isinstance(analyse, dict) else 0\n    a_faire = analyse.get('a_faire', 0) if isinstance(analyse, dict) else 0\n    titres = analyse.get('titres_en_attente', []) if isinstance(analyse, dict) else []\n    new_id = creation.get('id', '?') if isinstance(creation, dict) else '?'\n    new_title = str(creation.get('title', '?'))[:40] if isinstance(creation, dict) else '?'\n    val_done = validation.get('completed', False) if isinstance(validation, dict) else False\n    del_ok = suppression == {} or suppression == '{}'\n    lines = [sep, '  TABLEAU DE BORD PROJET', '  Genere le ' + now, sep, '', '-- ETAT DES TACHES (GET /todos?userId=1) --', '  Total    : ' + str(total), '  Terminees: ' + str(faites), '  En cours : ' + str(a_faire)]\n    for t in titres:\n        lines.append('    - ' + str(t))\n    lines += ['', '-- OPERATIONS CRUD --', '  POST   Creer tache     : #' + str(new_id) + ' \"' + new_title + '\"', '  PUT    Valider tache #1 : completed = ' + str(val_done), '  DELETE Supprimer tache#5: ' + ('OK' if del_ok else 'echec'), '', thin, '  RECOMMANDATIONS AGENT', thin, '', str(recommandations), '', sep]\n    content = '\\n'.join(lines)\n    filename = 'workflows/rapport_' + datetime.now().strftime('%Y%m%d_%H%M%S') + '.txt'\n    os.makedirs('workflows', exist_ok=True)\n    with open(filename, 'w', encoding='utf-8') as f:\n        f.write(content)\n    return 'Rapport ecrit dans ' + filename + '\\n\\n' + content",
        "detected_inputs": ["analyse", "creation", "validation", "suppression", "recommandations"],
        "detected_outputs": ["output"]
      },
      "input_ports": [
        {"id": "tdb-scr-008-analyse",         "name": "analyse",         "direction": "input", "data_type": "any", "required": true},
        {"id": "tdb-scr-008-creation",         "name": "creation",        "direction": "input", "data_type": "any", "required": true},
        {"id": "tdb-scr-008-validation",       "name": "validation",      "direction": "input", "data_type": "any", "required": true},
