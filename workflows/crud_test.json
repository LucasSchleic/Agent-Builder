        "script_code": "def run(synthese, audit):\n    from datetime import datetime\n    import os\n    now = datetime.now().strftime('%d/%m/%Y %H:%M')\n    sep = '=' * 60\n    thin = '-' * 60\n    content = sep + '\\n  RAPPORT AUDIT CRUD\\n  Genere le ' + now + '\\n' + sep + '\\n\\n' + synthese + '\\n\\n' + thin + '\\n  AUDIT AGENT QA\\n' + thin + '\\n\\n' + audit + '\\n\\n' + sep\n    filename = 'workflows/rapport_' + datetime.now().strftime('%Y%m%d_%H%M%S') + '.txt'\n    os.makedirs('workflows', exist_ok=True)\n    with open(filename, 'w', encoding='utf-8') as f:\n        f.write(content)\n    return 'Rapport ecrit dans ' + filename + '\\n\\n' + content",
