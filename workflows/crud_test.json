        "script_code": "def run(get_result, put_result, post_result, delete_result):\n    g = get_result.get('title', '?')[:55] if isinstance(get_result, dict) else str(get_result)[:55]\n    p = put_result.get('title', '?')[:55] if isinstance(put_result, dict) else str(put_result)[:55]\n    pid = post_result.get('id', '?') if isinstance(post_result, dict) else '?'\n    lines = [\n        '=== SYNTHESE CRUD ===',\n        '',\n        '  GET    /posts/42  : ' + g,\n        '  POST   /posts     : ID=' + str(pid),\n        '  PUT    /posts/42  : ' + p,\n        '  DELETE /posts/' + str(pid) + ' : ' + str(delete_result)[:50],\n        '',\n        '4 operations testees — jsonplaceholder.typicode.com'\n    ]\n    return '\\n'.join(lines)",
        "detected_inputs": ["get_result", "put_result", "post_result", "delete_result"],
        "detected_outputs": ["output"]
