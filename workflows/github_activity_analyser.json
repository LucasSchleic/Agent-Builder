      "type": "PythonScriptBlock",
      "name": "Sauvegarder Rapport",
      "config": {
        "function_name": "run",
        "script_code": "def run(rapport):\n    import os\n    from pathlib import Path\n    RAPPORT_DIR = 'rapports'\n    Path(RAPPORT_DIR).mkdir(exist_ok=True)\n    out_path = f\"{RAPPORT_DIR}/github_activity.txt\"\n    with open(out_path, 'w', encoding='utf-8') as f:\n        f.write(rapport)\n    print(f\"[OK] Rapport sauvegarde -> {out_path}\")\n    print(\"\\n\" + rapport)\n    return out_path\n",
        "detected_inputs": [
          "rapport"
        ],
        "detected_outputs": [
          "output"
        ],
        "detected_config": {
          "RAPPORT_DIR": {
            "label": "Rapport Dir",
            "default": "rapports",
            "value": "rapports"
          }
        }
