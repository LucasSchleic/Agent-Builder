# ==============================================================================
# Agent Builder — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ==============================================================================

# Django
DJANGO_SECRET_KEY=change-me-generate-a-real-secret-key
DJANGO_DEBUG=True

# Capgemini GenAI Platform
GENAI_API_URL=https://generative-eu.engine.capgemini.com/api/v1
GENAI_API_KEY=your-capgemini-api-key-here
GENAI_MODEL=gpt-4o
