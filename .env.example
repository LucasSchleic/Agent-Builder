# ==============================================================================
# Agent Builder — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ==============================================================================

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-generate-a-real-secret-key
DJANGO_DEBUG=True

# ── Capgemini GenAI Platform ──────────────────────────────────────────────────
GENAI_API_URL=https://generative-eu.engine.capgemini.com/api/v1
GENAI_API_KEY=your-capgemini-api-key-here
GENAI_MODEL=gpt-4o

# ── La Poste Mail ─────────────────────────────────────────────────────────────
# SMTP : smtp.laposte.net:465 (SSL) ou :587 (STARTTLS)
# Auth : adresse + mot de passe laposte.net (pas d'app password requis)
LAPOSTE_USER=your-address@laposte.net
LAPOSTE_PASSWORD=your-laposte-password

# ── Gmail (App Password) ──────────────────────────────────────────────────────
# Activer sur https://myaccount.google.com/apppasswords (2FA requis)
GMAIL_USER=your-address@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Outlook / Microsoft 365 ───────────────────────────────────────────────────
# App Password (compte perso) : https://account.microsoft.com/security → App passwords
# SMTP : smtp-mail.outlook.com:587 (STARTTLS)
OUTLOOK_USER=your-address@outlook.com
OUTLOOK_APP_PASSWORD=your-app-password
# OAuth2 (compte pro M365) — Azure App Registration
# https://portal.azure.com → App registrations → client credentials
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-tenant-id

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token — scopes: repo, read:org
# https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# ── Slack ─────────────────────────────────────────────────────────────────────
# Bot token — scopes: chat:write, channels:read
# https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-...
SLACK_DEFAULT_CHANNEL=#general

# ── Jira (Atlassian) ──────────────────────────────────────────────────────────
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-org.atlassian.net
JIRA_USER=your-email@company.com
JIRA_API_TOKEN=your-atlassian-api-token

# ── Notion ────────────────────────────────────────────────────────────────────
# https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=your-database-id

# ── Serper (web search dans les workflows agents) ─────────────────────────────
# https://serper.dev
SERPER_API_KEY=your-serper-key
