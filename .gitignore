# ==============================================================================
# Agent Builder — .gitignore
# ==============================================================================

# Environment variables — NEVER commit
.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
venv/
.venv/
env/

# Django
*.sqlite3
staticfiles/
media/

# IDEs
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code — settings files may contain sensitive info
.claude/settings.json
.claude/settings.local.json

# Generated workflow outputs — runtime artifacts, not source
workflows/rapport_*.txt
workflows/*.py
email_drafts/
rapports/

# Custom block templates — user-local, not versionned (except .gitkeep)
custom_blocks/*.json
